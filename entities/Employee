{
  "name": "Employee",
  "type": "object",
  "properties": {
    "first_name": {
      "type": "string",
      "description": "Employee first name"
    },
    "last_name": {
      "type": "string",
      "description": "Employee last name"
    },
    "email": {
      "type": "string",
      "description": "Employee email"
    },
    "phone": {
      "type": "string",
      "description": "Contact phone"
    },
    "position_id": {
      "type": "string",
      "description": "Reference to assigned Position"
    },
    "hire_date": {
      "type": "string",
      "format": "date",
      "description": "Date of hire"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "on_leave",
        "terminated"
      ],
      "default": "active"
    }
  },
  "required": [
    "first_name",
    "last_name"
  ]
}